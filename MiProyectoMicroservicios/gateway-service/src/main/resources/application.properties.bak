spring.cloud.gateway.server.webmvc.routes[5].uri=http://localhost:8086
spring.cloud.gateway.server.webmvc.routes[5].predicates[0]=Path=/api/v1/asistencia/**

# 7. Inscripciones Service
spring.cloud.gateway.server.webmvc.routes[6].id=inscripciones-service
spring.cloud.gateway.server.webmvc.routes[6].uri=http://localhost:8087
spring.cloud.gateway.server.webmvc.routes[6].predicates[0]=Path=/api/v1/inscripciones/**

# 8. Inventario Service
spring.cloud.gateway.server.webmvc.routes[7].id=inventario-service
spring.cloud.gateway.server.webmvc.routes[7].uri=http://localhost:8088
spring.cloud.gateway.server.webmvc.routes[7].predicates[0]=Path=/api/v1/inventario/**

# 9. Notificaciones Service
spring.cloud.gateway.server.webmvc.routes[8].id=notificaciones-service
spring.cloud.gateway.server.webmvc.routes[8].uri=http://localhost:8089
spring.cloud.gateway.server.webmvc.routes[8].predicates[0]=Path=/api/v1/notificaciones/**

# 10. Reportes Service
spring.cloud.gateway.server.webmvc.routes[9].id=reportes-service
spring.cloud.gateway.server.webmvc.routes[9].uri=http://localhost:8090
spring.cloud.gateway.server.webmvc.routes[9].predicates[0]=Path=/api/v1/reportes/**

# 11. Apoderados Service
spring.cloud.gateway.server.webmvc.routes[10].id=apoderados-service
spring.cloud.gateway.server.webmvc.routes[10].uri=http://localhost:8091
spring.cloud.gateway.server.webmvc.routes[10].predicates[0]=Path=/api/v1/apoderados/**