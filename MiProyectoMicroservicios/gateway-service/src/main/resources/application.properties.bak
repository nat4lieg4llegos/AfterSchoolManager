# ==========================================
# CONFIGURACION PRINCIPAL DEL GATEWAY
# ==========================================
server.port=8080
spring.application.name=gateway-service

# ==========================================
# CONFIGURACION CORS
# ==========================================
spring.cloud.gateway.server.webmvc.globalcors.cors-configurations.[/**].allowed-origins=*
spring.cloud.gateway.server.webmvc.globalcors.cors-configurations.[/**].allowed-methods=GET,POST,PUT,PATCH,DELETE,OPTIONS
spring.cloud.gateway.server.webmvc.globalcors.cors-configurations.[/**].allowed-headers=*

# ==========================================
# RUTAS DE LOS 11 MICROSERVICIOS
# ==========================================

# 1. Auth Service
spring.cloud.gateway.server.webmvc.routes[0].id=auth-service
spring.cloud.gateway.server.webmvc.routes[0].uri=http://localhost:8092
spring.cloud.gateway.server.webmvc.routes[0].predicates[0]=Path=/api/v1/auth/**

# 2. Estudiante Service
spring.cloud.gateway.server.webmvc.routes[1].id=estudiante-service
spring.cloud.gateway.server.webmvc.routes[1].uri=http://localhost:8081
spring.cloud.gateway.server.webmvc.routes[1].predicates[0]=Path=/api/v1/estudiantes/**

# 3. Talleres Service
spring.cloud.gateway.server.webmvc.routes[2].id=talleres-service
spring.cloud.gateway.server.webmvc.routes[2].uri=http://localhost:8083
spring.cloud.gateway.server.webmvc.routes[2].predicates[0]=Path=/api/v1/talleres/**

# 4. Tutores Service
spring.cloud.gateway.server.webmvc.routes[3].id=tutores-service
spring.cloud.gateway.server.webmvc.routes[3].uri=http://localhost:8084
